#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/lumalabs/luma-agents-go,github.com/stainless-sdks/luma-agents-go"

echo "==> Building luma-agents-cli"
go build ./cmd/luma-agents-cli
